{
  "name": "@atelier/cli",
  "version": "0.1.0",
  "description": "Atelier CLI — autonomous serious-literary writing system: thematic analysis, character psychology, symbolic networks, 20-dimension literary audit (incl. anti-AI-trace).",
  "keywords": [
    "literary-fiction",
    "serious-fiction",
    "ai-writing-agent",
    "multi-agent",
    "thematic-analysis",
    "character-psychology",
    "symbolic-network",
    "literary-audit",
    "anti-ai-detection",
    "cli"
  ],
  "type": "module",
  "bin": {
    "atelier": "dist/index.js"
  },
  "files": [
    "dist",
    "!dist/__tests__"
  ],
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/hughtty/atelier.git",
    "directory": "packages/cli"
  },
  "scripts": {
    "prepare:workspace-core": "pnpm --filter @atelier/core build",
    "prepack": "node ../../scripts/prepare-package-for-publish.mjs",
    "postpack": "node ../../scripts/restore-package-json.mjs",
    "prepublishOnly": "node ../../scripts/verify-no-workspace-protocol.mjs .",
    "prebuild": "pnpm run prepare:workspace-core",
    "build": "tsc",
    "dev": "tsc --watch",
    "pretest": "pnpm run build",
    "test": "vitest run --passWithNoTests",
    "pretypecheck": "pnpm run prepare:workspace-core",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@atelier/core": "workspace:*",
    "@atelier/studio": "workspace:*",
    "commander": "^13.0.0",
    "dotenv": "^16.4.0",
    "epub-gen-memory": "^1.0.10",
    "ink": "^7.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "@mariozechner/pi-ai": "0.67.1",
    "@mariozechner/pi-agent-core": "0.67.1"
  }
}
